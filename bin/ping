#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
	exit 1
fi

for arg in "$@"; do
	if [[ "$arg" =~ ^[a-zA-Z][a-zA-Z0-9+.-]*:// ]]; then
		rest="${arg#*://}"
		host="${rest%%/*}"
		host="${host%%:*}"
		args+=("$host")
		>&2 echo "(ping ${host})"
	else
		args+=("$arg")
	fi
done

/usr/bin/ping "${args[@]}"
