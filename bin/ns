#! /usr/bin/env bash
set -e

CMD="/run/current-system/sw/bin/nix-shell"

# 不断往上递归，看哪个目录有 Makefile 可以 make

DIR=$(pwd)
CURRENT=1
FOUND=''
FILE_BASE="shell.nix"

while [ "$DIR" != '/' ]
do

	FILE="${DIR}/${FILE_BASE}"

	if [ -e "$FILE" ]; then

		FOUND='true'

		if [ "$CURRENT" != 1 ]; then
			echo "nix-shell with $FILE"
			echo
		fi

		cd "$DIR" || exit
		"$CMD" "$@"
		break
	fi

	CURRENT=0
	DIR=$(dirname "$DIR")
done

if [ -z "$FOUND" ]; then
	>&2 echo "$FILE_BASE not found"
	exit 1
fi
