#!/usr/bin/env bash
set -e

CMD="/run/current-system/sw/bin/make"
if [ ! -x "$CMD" ]; then
	CMD="/usr/bin/make"
fi

echo "$CMD"

# 不断往上递归，看哪个目录有 Makefile 可以 make

DIR=$(pwd)
CURRENT=1
FOUND=''

while [ "$DIR" != '/' ]
do

	FILE="${DIR}/Makefile"

	if [ -e "$FILE" ]; then

		FOUND='true'

		if [ "$CURRENT" != 1 ]; then
			echo "$FILE"
			echo
		fi

		cd "$DIR" || exit
		"$CMD" "$@"
		break
	fi

	CURRENT=0
	DIR=$(dirname "$DIR")
done

if [ -z "$FOUND" ]; then
	>&2 echo Makefile not found
	exit 1
fi
